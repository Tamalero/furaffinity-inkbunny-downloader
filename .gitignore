# Virtual environment
venv/

# Python bytecode
__pycache__/
*.pyc
*.pyo
*.pyd

# Downloaded artwork output
FAIBDownload/

# Claude Code local settings
.claude/

# Credentials / session data (stored in ~/.config/faibdownloader/ at runtime,
